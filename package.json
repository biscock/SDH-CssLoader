{
  "name": "SDH-CssLoader",
  "type": "module",
  "version": "2.2.0",
  "description": "A css loader",
  "scripts": {
    "build": "shx rm -rf dist && pnpx @tailwindcss/cli -i ./src/styles/main.css -o ./src/styles/output.css && rollup -c",
    "watch": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suchmememanyskill/SDH-CssLoader.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "plugin-template",
    "steam-deck",
    "deck"
  ],
  "author": "Deckthemes",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/SteamDeckHomebrew/decky-plugin-template/issues"
  },
  "homepage": "https://github.com/SteamDeckHomebrew/decky-plugin-template#readme",
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.0",
    "@types/color": "^3.0.3",
    "@types/lodash": "^4.14.191",
    "@types/react": "16.14.0",
    "@types/webpack": "^5.28.0",
    "rollup": "^4.24.4",
    "shx": "^0.3.4",
    "tslib": "^2.4.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@decky/api": "^1.1.2",
    "@decky/rollup": "^1.0.1",
    "@decky/ui": "^4.9.1",
    "@tailwindcss/cli": "^4.0.15",
    "clsx": "^2.1.1",
    "color": "^4.2.3",
    "lodash": "^4.17.21",
    "react-icons": "^4.12.0",
    "rollup-plugin-import-css": "^3.5.8",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^4.0.15",
    "zustand": "^4.5.2",
    "zusteebles": "^0.0.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  },
  "packageManager": "pnpm@9.9.0+sha512.60c18acd138bff695d339be6ad13f7e936eea6745660d4cc4a776d5247c540d0edee1a563695c183a66eb917ef88f2b4feb1fc25f32a7adcadc7aaf3438e99c1"
}
